# ============================================================
# Backend Environment Variables  (.env.example)
# Copy this to .env and fill in your real values
# ============================================================

# Server
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/matchingService   # Or your Atlas URI

# JWT — used for all access tokens (register, login, OAuth callbacks)
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars

# CORS origin for your frontend
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000    # Used to build file upload URLs

# Polar (Subscriptions & Payments) — leave blank to disable
POLAR_API_KEY=
POLAR_WEBHOOK_SECRET=
POLAR_SELLER_PRO_PRICE_ID=
POLAR_SELLER_ELITE_PRICE_ID=
POLAR_BUYER_PRO_PRICE_ID=
POLAR_BUYER_ELITE_PRICE_ID=

# Email (Nodemailer) — for password resets & email verification
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Discord OAuth (optional)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5000/api/auth/discord/callback

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
